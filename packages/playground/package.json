{
  "name": "@rivet-dev/agent-os-playground",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run setup-vendor && pnpm run build:assets",
    "build:assets": "tsx ./scripts/build-worker.ts",
    "check": "pnpm run build:assets",
    "check-types": "tsc --noEmit -p ./tsconfig.json",
    "dev": "pnpm run setup-vendor && pnpm run build:assets && tsx ./backend/server.ts",
    "setup-vendor": "tsx ./scripts/setup-vendor.ts",
    "test": "pnpm exec vitest run ./tests/"
  },
  "dependencies": {
    "@rivet-dev/agent-os-browser": "workspace:*",
    "secure-exec": "link:../../../secure-exec-1/packages/secure-exec"
  },
  "devDependencies": {
    "esbuild": "^0.27.1",
    "monaco-editor": "0.52.2",
    "pyodide": "0.28.3",
    "typescript": "5.9.3"
  }
}
